---
/**
 * About — short LinkedIn-style intro that sits between Hero and Scorecard.
 *
 * Layout:
 *   lg+: 12-col grid. Portrait spans col-span-5 (left), body spans col-span-7 (right).
 *   md and below: portrait stacks above body, constrained to max-w-sm and centered.
 *
 * Portrait treatment (Option B): portrait-crop (4:5), rounded-3xl, hairline gold border,
 * inset cream ring. Image is optimized via Astro's <Image> component — AVIF + WebP +
 * JPG fallback at responsive widths.
 */
import { Picture } from 'astro:assets';
import { about } from '../data/content';
import portrait from '../assets/portrait.jpg';
import SectionHeader from './SectionHeader.astro';
---

<section id="about" class="relative bg-cream-paper py-16 sm:py-20">
  <div class="container-club">
    <SectionHeader eyebrow={about.eyebrow} title={about.title} />

    <div class="mt-12 grid grid-cols-1 gap-10 lg:grid-cols-12 lg:items-center lg:gap-12">
      <!-- Portrait column (left on lg+, top on smaller) -->
      <div class="lg:col-span-5">
        <div class="mx-auto w-full max-w-sm lg:max-w-none">
          <!-- Framed plate: rounded square, hairline gold, soft shadow, inset cream ring. -->
          <figure
            class="relative aspect-[4/5] w-full overflow-hidden rounded-3xl border border-gold/60 bg-fairway shadow-card ring-1 ring-inset ring-cream/10"
          >
            <Picture
              src={portrait}
              alt={about.portrait.alt}
              formats={['avif', 'webp']}
              fallbackFormat="jpg"
              widths={[400, 600, 800, 1200, 1447]}
              sizes="(min-width: 1024px) 40vw, 80vw"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 h-full w-full object-cover"
            />
          </figure>

          <!-- Caption strip below the framed plate -->
          <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-widest2 text-charcoal-muted">
            {about.portrait.caption}
          </p>
        </div>
      </div>

      <!-- Copy column (right on lg+, below on smaller) -->
      <div class="lg:col-span-7">
        <div class="space-y-4 sm:space-y-5">
          {(() => {
            // Each token in this map gets wrapped in an external anchor — but
            // only on its FIRST occurrence in a given paragraph. Subsequent
            // mentions of the same token (and shorter substrings of it, e.g.
            // a bare "Tip10" after "Tip10 Technologies" was already linked)
            // remain plain text.
            const linkMap = [
              { text: 'LinkedIn', href: 'https://www.linkedin.com' },
              { text: 'Tip10 Technologies', href: 'https://tip10.tech' },
            ];

            const anchorClass =
              'font-medium text-fairway underline decoration-gold/60 underline-offset-4 transition-colors duration-200 hover:text-gold hover:decoration-gold focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-cream';

            // Splits a paragraph into a node array. Walks the remaining text,
            // finds the earliest unused token, and wraps that single hit in an
            // anchor; the suffix is processed with that token removed from the
            // available set. Order of `tokens` is irrelevant — earliest match
            // in the string wins, which keeps in-prose ordering natural.
            const renderParagraphWithLinks = (
              text: string,
              tokens: { text: string; href: string }[],
            ): (string | { kind: 'link'; text: string; href: string })[] => {
              if (tokens.length === 0 || text.length === 0) return [text];
              let earliest: { token: typeof tokens[number]; index: number } | null = null;
              for (const token of tokens) {
                const index = text.indexOf(token.text);
                if (index === -1) continue;
                if (earliest === null || index < earliest.index) {
                  earliest = { token, index };
                }
              }
              if (earliest === null) return [text];
              const { token, index } = earliest;
              const remainingTokens = tokens.filter((t) => t.text !== token.text);
              const prefix = text.slice(0, index);
              const suffix = text.slice(index + token.text.length);
              return [
                prefix,
                { kind: 'link' as const, text: token.text, href: token.href },
                ...renderParagraphWithLinks(suffix, remainingTokens),
              ];
            };

            return about.body.map((paragraph) => {
              const nodes = renderParagraphWithLinks(paragraph, linkMap);
              return (
                <p class="text-lg leading-relaxed text-charcoal sm:text-xl">
                  {nodes.map((node) =>
                    typeof node === 'string' ? (
                      node
                    ) : (
                      <a
                        href={node.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class={anchorClass}
                      >
                        {node.text}
                        <span class="sr-only">(opens in a new tab)</span>
                      </a>
                    ),
                  )}
                </p>
              );
            });
          })()}
        </div>
        <div class="mt-8 flex items-center gap-3">
          <span class="rule-gold"></span>
          <span class="font-mono text-[11px] uppercase tracking-widest2 text-charcoal-muted">
            Member · Story
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
