---
/**
 * About — short LinkedIn-style intro that sits between Hero and Scorecard.
 *
 * Layout:
 *   lg+: 12-col grid. Portrait spans col-span-5 (left), body spans col-span-7 (right).
 *   md and below: portrait stacks above body, constrained to max-w-sm and centered.
 *
 * Portrait treatment (Option B): portrait-crop (4:5), rounded-3xl, hairline gold border,
 * fairway-green monogram placeholder until `about.portrait.src` is set in content.ts.
 */
import { about } from '../data/content';
import SectionHeader from './SectionHeader.astro';

const portrait = about.portrait;
const hasPortraitSrc = Boolean(portrait.src);
---

<section id="about" class="relative bg-cream-paper py-16 sm:py-20">
  <div class="container-club">
    <SectionHeader eyebrow={about.eyebrow} title={about.title} />

    <div class="mt-12 grid gap-10 lg:grid-cols-12 lg:gap-12">
      <!-- Portrait column (left on lg+, top on smaller) -->
      <div class="col-span-12 lg:col-span-5">
        <div class="mx-auto w-full max-w-sm lg:max-w-none">
          <!-- Framed plate: rounded square, hairline gold, soft shadow, inset cream ring. -->
          <figure
            class="relative aspect-[4/5] w-full overflow-hidden rounded-3xl border border-gold/60 bg-fairway shadow-card ring-1 ring-inset ring-cream/10"
            role={hasPortraitSrc ? undefined : 'img'}
            aria-label={hasPortraitSrc ? undefined : `Placeholder for ${portrait.alt}'s portrait`}
          >
            {hasPortraitSrc ? (
              <img
                src={portrait.src}
                alt={portrait.alt}
                width="800"
                height="1000"
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover"
              />
            ) : (
              <!-- Monogram placeholder: fairway-green plate with subtle grain, engraved DT, hairline rule, and label. -->
              <div class="absolute inset-0 bg-fairway-grain bg-grain opacity-60"></div>
              <div class="relative flex h-full w-full flex-col items-center justify-center px-6 text-center">
                <span
                  class="select-none font-display leading-none text-cream/90"
                  style="font-size: clamp(5rem, 12vw, 8rem);"
                  aria-hidden="true"
                >
                  DT
                </span>
                <span class="mt-5 block h-px w-12 bg-gold"></span>
                <span class="mt-4 font-mono text-[10px] uppercase tracking-widest2 text-cream/60">
                  Member’s Portrait · Placeholder
                </span>
              </div>
            )}
          </figure>

          <!-- Caption strip below the framed plate -->
          <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-widest2 text-charcoal-muted">
            {portrait.caption}
          </p>
        </div>
      </div>

      <!-- Copy column (right on lg+, below on smaller) -->
      <div class="col-span-12 lg:col-span-7">
        <p class="text-lg leading-relaxed text-charcoal sm:text-xl">
          {about.body}
        </p>
        <div class="mt-8 flex items-center gap-3">
          <span class="rule-gold"></span>
          <span class="font-mono text-[11px] uppercase tracking-widest2 text-charcoal-muted">
            Member · Story
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
