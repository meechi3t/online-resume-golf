---
import { clubhouse } from '../data/content';
import SectionHeader from './SectionHeader.astro';
---

<section id="clubhouse" class="relative bg-cream-deep py-24 sm:py-28">
  <div class="container-club">
    <SectionHeader
      eyebrow={`The Clubhouse · ${clubhouse.subtitle}`}
      title={clubhouse.title}
    />

    <div class="mt-12 grid gap-10 lg:grid-cols-12 lg:gap-12">
      <!-- Pull-quote panel -->
      <blockquote class="card relative col-span-12 border-fairway/15 lg:col-span-7">
        <!-- Decorative quote serif -->
        <span
          class="pointer-events-none absolute -top-2 left-6 select-none font-display text-7xl leading-none text-gold/40"
          aria-hidden="true"
        >
          &ldquo;
        </span>
        <p class="mt-2 font-display text-2xl leading-relaxed text-fairway sm:text-3xl">
          {clubhouse.body}
        </p>
        <footer class="mt-8 flex items-center gap-3">
          <span class="rule-gold"></span>
          <span class="font-mono text-[11px] uppercase tracking-widest2 text-charcoal-muted">
            Tipton · House Rules
          </span>
        </footer>
      </blockquote>

      <!-- Pillars -->
      <div class="col-span-12 grid gap-4 sm:grid-cols-3 lg:col-span-5 lg:grid-cols-1">
        {clubhouse.pillars.map((pillar, i) => (
          <article class="card border-fairway/10 p-6">
            <div class="flex items-center justify-between">
              <span class="font-mono text-[10px] uppercase tracking-widest2 text-gold">
                {`P0${i + 1}`}
              </span>
              <span class="h-px w-8 bg-gold/50"></span>
            </div>
            <h3 class="mt-3 font-display text-2xl text-fairway">{pillar.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-charcoal-muted">{pillar.body}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
