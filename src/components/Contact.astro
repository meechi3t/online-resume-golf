---
import { contact, site } from '../data/content';
---

<section id="contact" class="relative isolate overflow-hidden bg-fairway-dark py-20 text-cream sm:py-24">
  <!-- Decorative pin + flag, far right -->
  <svg
    class="pointer-events-none absolute -right-8 -top-8 h-72 w-72 opacity-[0.18]"
    viewBox="0 0 200 200"
    fill="none"
    aria-hidden="true"
  >
    <line x1="60" y1="20" x2="60" y2="180" stroke="#C9A961" stroke-width="1.4" />
    <path d="M60,28 L150,52 L60,76 Z" fill="#C9A961" opacity="0.85" />
    <circle cx="60" cy="180" r="3" fill="#C9A961" />
  </svg>

  <div class="container-club relative">
    <div class="flex items-center gap-3">
      <span class="h-px w-12 bg-gold"></span>
      <span class="font-mono text-[11px] uppercase tracking-widest2 text-gold">
        The 18th Green · Contact
      </span>
    </div>

    <h2 class="mt-4 max-w-3xl text-balance font-display text-5xl leading-[1.05] text-cream sm:text-6xl">
      {contact.title}
    </h2>
    <p class="mt-6 max-w-2xl text-balance text-lg leading-relaxed text-cream/75">
      {contact.caption}
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      {contact.links.map((link) => (
        <a
          href={link.href}
          class="group rounded-2xl border border-cream/15 bg-fairway/40 p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-gold hover:bg-fairway-light"
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          download={link.label === 'Resume' ? true : undefined}
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-[10px] uppercase tracking-widest2 text-gold">
              {link.label}
            </span>
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              class="text-gold transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1"
              aria-hidden="true"
            >
              <path
                d="M5 11L11 5M11 5H5.5M11 5V10.5"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </div>
          <p class="mt-4 font-display text-xl text-cream">{link.display}</p>
        </a>
      ))}
    </div>

    <div class="mt-14 flex flex-wrap items-center gap-4">
      <a
        href={contact.links[0]!.href}
        class="btn bg-gold text-fairway-dark hover:bg-gold-soft"
      >
        {contact.cta}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3 7H11M11 7L7.5 3.5M11 7L7.5 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href={site.resumePdf}
        download
        class="btn border border-cream/30 bg-transparent text-cream hover:border-gold"
      >
        Download Resume
      </a>
    </div>
  </div>
</section>
