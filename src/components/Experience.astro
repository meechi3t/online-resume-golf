---
import { experience, credentials } from '../data/content';
import SectionHeader from './SectionHeader.astro';

const backNine = experience.roles.filter((r) => r.side === 'back-nine');
const frontNine = experience.roles.filter((r) => r.side === 'front-nine');
const allCredentials = [credentials.education, ...credentials.certifications];
---

<section id="experience" class="relative bg-cream py-16 sm:py-20">
  <div class="container-club">
    <SectionHeader
      eyebrow="The Round · Front Nine to Back Nine"
      title={experience.title}
      caption={experience.caption}
    />

    <div class="mt-14 grid gap-10 lg:grid-cols-2 lg:gap-12">
      <!-- Back Nine: current concurrent rounds -->
      <div>
        <div class="mb-6 flex items-center justify-between">
          <span class="eyebrow">Back Nine · Now Playing</span>
          <span class="font-mono text-[10px] uppercase tracking-widest2 text-charcoal-muted">
            Holes 10 — 18
          </span>
        </div>

        <div class="space-y-6">
          {backNine.map((role) => (
            <article class="card border-fairway/15">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <h3 class="font-display text-2xl text-fairway sm:text-3xl">
                  {role.company}
                </h3>
                <span class="font-mono text-[11px] uppercase tracking-widest2 text-gold">
                  {role.period}
                </span>
              </div>
              <p class="mt-1 text-sm font-medium text-charcoal">
                {role.title}
              </p>
              {role.location && (
                <p class="mt-1 font-mono text-[11px] uppercase tracking-widest2 text-charcoal-muted">
                  {role.location}
                </p>
              )}
              <div class="hairline mt-5"></div>
              <ul class="mt-5 space-y-3">
                {role.focus.map((item) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-charcoal-soft">
                    <span class="mt-2 h-1 w-1 flex-none rounded-full bg-gold"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>

      <!-- Front Nine: earlier rounds -->
      <div>
        <div class="mb-6 flex items-center justify-between">
          <span class="eyebrow">Front Nine · Earlier Rounds</span>
          <span class="font-mono text-[10px] uppercase tracking-widest2 text-charcoal-muted">
            Holes 01 — 09
          </span>
        </div>

        <div class="space-y-6">
          {frontNine.map((role) => (
            <article class="card border-fairway/15 bg-cream">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <h3 class="font-display text-2xl text-fairway sm:text-3xl">
                  {role.company}
                </h3>
                <span class="font-mono text-[11px] uppercase tracking-widest2 text-charcoal-muted">
                  {role.period}
                </span>
              </div>
              <p class="mt-1 text-sm font-medium text-charcoal">
                {role.title}
              </p>
              {role.location && (
                <p class="mt-1 font-mono text-[11px] uppercase tracking-widest2 text-charcoal-muted">
                  {role.location}
                </p>
              )}
              <div class="hairline mt-5"></div>
              <ul class="mt-5 space-y-3">
                {role.focus.map((item) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-charcoal-soft">
                    <span class="mt-2 h-1 w-1 flex-none rounded-full bg-fairway/40"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </div>

    <!-- Member's Credentials rail: education + certifications -->
    <div class="mt-16">
      <div class="flex items-center gap-3">
        <span class="rule-gold"></span>
        <span class="eyebrow">Member’s Card · Credentials</span>
      </div>

      <ul class="mt-6 grid gap-4 sm:grid-cols-3">
        {allCredentials.map((c) => (
          <li class="rounded-2xl border border-fairway/15 bg-cream-paper p-5 shadow-card">
            <div class="flex items-center justify-between">
              <span class="font-mono text-[10px] uppercase tracking-widest2 text-gold">
                {c.label}
              </span>
              <span class="h-px w-10 bg-gold/50"></span>
            </div>
            <p class="mt-3 font-display text-xl leading-tight text-fairway">
              {c.detail}
            </p>
            {c.meta && (
              <p class="mt-1 font-mono text-[10px] uppercase tracking-widest2 text-charcoal-muted">
                {c.meta}
              </p>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
