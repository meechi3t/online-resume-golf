---
/**
 * Subtle decorative divider — three horizontal fairway lines tapering toward
 * a center flag pin. Decorative only; hidden from assistive tech.
 */
---

<div class="my-12 flex items-center justify-center gap-3" aria-hidden="true">
  <span class="hairline w-24 sm:w-40"></span>
  <svg
    width="14"
    height="20"
    viewBox="0 0 14 20"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="text-gold"
  >
    <path
      d="M2 19V1L12 4.5L2 8"
      stroke="currentColor"
      stroke-width="1"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <circle cx="2" cy="19" r="1.2" fill="currentColor" />
  </svg>
  <span class="hairline w-24 sm:w-40"></span>
</div>
