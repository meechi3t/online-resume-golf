---
import { Picture } from 'astro:assets';
import { hero, site } from '../data/content';
import heroImage from '../assets/hero.jpg';
---

<section
  id="top"
  class="relative isolate overflow-hidden bg-fairway text-cream"
>
  <!-- Layered fairway gradient backdrop. Tunable via tailwind colors in tailwind.config.mjs. -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br from-fairway-dark via-fairway to-fairway-light"
    aria-hidden="true"
  ></div>

  <!-- Subtle grain to evoke felt / fairway texture -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-fairway-grain bg-grain opacity-50"
    aria-hidden="true"
  ></div>

  <!--
    Decorative fairway-sweep SVG removed in favor of the hero photograph.
    See git history (feat/hero-image) for the previous decorative element.
  -->

  <div class="container-club relative pb-24 pt-28 sm:pb-32 sm:pt-36 lg:pb-40 lg:pt-44">
    <div class="lg:grid lg:grid-cols-12 lg:items-center lg:gap-12">
      <!-- Left column: text content -->
      <div class="lg:col-span-7">
        <!-- Course tag — like a clubhouse plaque -->
        <div class="mb-10 flex items-center gap-3 animate-fade-in">
          <span class="h-px w-10 bg-gold"></span>
          <span class="font-mono text-[11px] uppercase tracking-widest2 text-gold">
            {hero.eyebrow}
          </span>
        </div>

        <div class="space-y-1">
          {hero.titles.map((line, i) => (
            <p
              class="font-mono text-xs uppercase tracking-widest2 text-cream/60 animate-fade-up"
              style={`animation-delay: ${i * 60}ms`}
            >
              {line}
            </p>
          ))}
        </div>

        <p
          class="mt-3 font-display text-xl italic text-gold/90 animate-fade-up sm:text-2xl"
          style="animation-delay: 40ms"
        >
          {hero.tagline}
        </p>

        <h1
          class="mt-4 max-w-4xl text-balance font-display text-5xl leading-[1.04] text-cream sm:text-6xl lg:text-7xl animate-fade-up"
          style="animation-delay: 80ms"
        >
          <span class="block">{hero.headline[0]}</span>
          <span class="mt-2 block sm:mt-3">{hero.headline[1]}</span>
        </h1>

        <p
          class="mt-8 max-w-2xl text-balance text-lg leading-relaxed text-cream/80 sm:text-xl animate-fade-up"
          style="animation-delay: 160ms"
        >
          {hero.intro}
        </p>

        <div
          class="mt-12 flex flex-wrap items-center gap-3 animate-fade-up"
          style="animation-delay: 240ms"
        >
          <a
            href="#experience"
            class="btn bg-gold text-fairway-dark hover:bg-gold-soft hover:shadow-card-hover"
          >
            View Experience
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M11 7L7.5 3.5M11 7L7.5 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href={site.resumePdf}
            download
            class="btn border border-cream/30 bg-transparent text-cream hover:border-gold hover:bg-cream/5"
          >
            Download Resume
          </a>
          <a
            href="#contact"
            class="btn bg-transparent text-cream/80 hover:text-cream"
          >
            Contact Me
          </a>
        </div>
      </div>

      <!-- Right column: hero image. On mobile, stacks between buttons and plaque. -->
      <div
        class="mt-12 lg:col-span-5 lg:mt-0 animate-fade-in-right"
        style="animation-delay: 200ms"
      >
        <div class="relative aspect-[3/2] overflow-hidden rounded-2xl border border-gold/30 shadow-card lg:aspect-[4/5]">
          <Picture
            src={heroImage}
            formats={['avif', 'webp']}
            fallbackFormat="jpg"
            widths={[600, 800, 1000, 1200]}
            sizes="(min-width: 1024px) 40vw, 100vw"
            alt="Coastal golf course at sunrise — the Tipton Course in spirit"
            loading="eager"
            fetchpriority="high"
            pictureAttributes={{ class: 'absolute inset-0 h-full w-full' }}
            class="absolute inset-0 h-full w-full object-cover object-[center_30%]"
          />
        </div>
      </div>

      <!-- Course plaque — full width under both columns on lg+ -->
      <div
        class="mt-20 flex flex-wrap items-center gap-x-6 gap-y-2 border-t border-cream/10 pt-6 animate-fade-up lg:col-span-12"
        style="animation-delay: 320ms"
      >
        <span class="font-mono text-[10px] uppercase tracking-widest2 text-cream/50">
          {hero.course}
        </span>
        <span class="hidden h-3 w-px bg-cream/20 sm:block"></span>
        <span class="font-mono text-[10px] uppercase tracking-widest2 text-cream/50">
          Par · Executive
        </span>
        <span class="hidden h-3 w-px bg-cream/20 sm:block"></span>
        <span class="font-mono text-[10px] uppercase tracking-widest2 text-cream/50">
          Yardage · 10+ Years
        </span>
      </div>
    </div>
  </div>

  <!-- Bottom hairline rule with center flag, transitions to next section -->
  <div class="hairline-gold absolute bottom-0 left-0 right-0"></div>
</section>
