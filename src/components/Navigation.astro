---
import { nav, site } from '../data/content';
---

<header class="sticky top-0 z-40 border-b border-fairway/10 bg-cream/85 backdrop-blur supports-[backdrop-filter]:bg-cream/70">
  <div class="container-club flex h-16 items-center justify-between">
    <a href="#top" class="group flex items-center gap-3">
      <!-- Monogram crest: minimal "DT" inside a hairline-gold ring. -->
      <span
        class="grid h-9 w-9 place-items-center rounded-full border border-gold/60 bg-fairway font-display text-sm font-medium text-cream transition-all duration-300 group-hover:border-gold"
        aria-hidden="true"
      >
        DT
      </span>
      <span class="flex items-baseline leading-tight">
        <span class="font-display text-base text-fairway">
          {site.name}
        </span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-7">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="font-mono text-[11px] uppercase tracking-widest2 text-charcoal-muted transition-colors duration-200 hover:text-fairway"
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href={site.resumePdf}
            class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-widest2 text-charcoal-muted transition-colors duration-200 hover:text-fairway"
            download
          >
            Resume
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M6 1V8M6 8L3 5M6 8L9 5M2 10H10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Mobile: just the resume CTA — content hub is one scroll away. -->
    <a
      href="#contact"
      class="rounded-full border border-fairway/30 px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest2 text-fairway md:hidden"
    >
      Contact
    </a>
  </div>
  <div class="hairline-gold"></div>
</header>
