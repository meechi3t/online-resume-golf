---
/**
 * Recommendations — verbatim LinkedIn excerpts (used with permission).
 * 3-column grid on lg, 2-column on sm, 1-column on mobile.
 * Card visual rhythm matches TrophyCase: hairline-gold corner brackets,
 * label-tag eyebrow, italic display pull-quote, gold rule, attribution.
 *
 * Each recommender's name is a clickable link to LinkedIn. Prefers an
 * explicit `linkedinUrl` if set on the data record; otherwise falls back
 * to a universal LinkedIn keyword-search URL (never wrong-person).
 */
import { recommendations } from '../data/content';
import SectionHeader from './SectionHeader.astro';

const buildSearchUrl = (name: string) =>
  `https://www.linkedin.com/search/results/all/?keywords=${encodeURIComponent(name)}`;
---

<section id="recommendations" class="relative bg-cream py-16 sm:py-20">
  <div class="container-club">
    <SectionHeader
      eyebrow={recommendations.eyebrow}
      title={recommendations.title}
      caption={recommendations.caption}
    />

    <ul class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {recommendations.items.map((rec) => (
        <li class="card group relative flex flex-col">
          <!-- Hairline-gold corner brackets, matching Trophy Case -->
          <span class="pointer-events-none absolute left-3 top-3 h-3 w-3 border-l border-t border-gold/60"></span>
          <span class="pointer-events-none absolute right-3 top-3 h-3 w-3 border-r border-t border-gold/60"></span>
          <span class="pointer-events-none absolute bottom-3 left-3 h-3 w-3 border-b border-l border-gold/60"></span>
          <span class="pointer-events-none absolute bottom-3 right-3 h-3 w-3 border-b border-r border-gold/60"></span>

          <div class="flex items-center justify-between">
            <span class="label-tag">
              <span class="h-1 w-1 rounded-full bg-gold"></span>
              {rec.initials} · {rec.role.split('·')[0]!.trim()}
            </span>
            <!-- Quotation mark icon -->
            <svg
              class="text-gold/80 transition-transform duration-500 group-hover:scale-110"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M5 8C5 6.34315 6.34315 5 8 5H8.5V6.5H8C7.17157 6.5 6.5 7.17157 6.5 8V8.5H8V13H4V8H5ZM12 8C12 6.34315 13.3431 5 15 5H15.5V6.5H15C14.1716 6.5 13.5 7.17157 13.5 8V8.5H15V13H11V8H12Z"
                stroke="currentColor"
                stroke-width="0.8"
                fill="currentColor"
                fill-opacity="0.15"
              />
            </svg>
          </div>

          <blockquote class="mt-5 font-display text-lg italic leading-snug text-fairway sm:text-xl">
            &ldquo;{rec.quote}&rdquo;
          </blockquote>

          <div class="mt-auto pt-6">
            <div class="hairline-gold mb-4"></div>
            <p class="font-display text-base text-fairway">
              <a
                href={rec.linkedinUrl ?? buildSearchUrl(rec.name)}
                target="_blank"
                rel="noopener noreferrer"
                class="group/link inline-flex items-center gap-1.5 rounded-sm text-fairway transition-colors duration-200 hover:text-gold focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-cream"
              >
                <span class="underline-offset-4 group-hover/link:underline group-hover/link:decoration-gold">
                  {rec.name}
                </span>
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 16 16"
                  fill="none"
                  class="text-gold/70 transition-transform duration-200 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5 group-hover/link:text-gold"
                  aria-hidden="true"
                >
                  <path
                    d="M5 11L11 5M11 5H5.5M11 5V10.5"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span class="sr-only">(opens LinkedIn in a new tab)</span>
              </a>
            </p>
            <p class="mt-1 text-sm leading-snug text-charcoal-muted">{rec.role}</p>
            <p class="mt-1 font-mono text-[10px] uppercase tracking-widest2 text-charcoal-muted">
              {rec.relationship}
            </p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
