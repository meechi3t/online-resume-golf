---
import { toolbag } from '../data/content';
import SectionHeader from './SectionHeader.astro';

// Group tools by category for the "club tag" sub-headers.
const grouped = toolbag.tools.reduce<Record<string, typeof toolbag.tools>>((acc, tool) => {
  (acc[tool.category] ||= []).push(tool);
  return acc;
}, {});

// Preserve a stable category order even if data shifts.
const categoryOrder = ['Cloud & Identity', 'Automation', 'Endpoints', 'Operations', 'AI'];
const orderedCategories = categoryOrder.filter((c) => grouped[c]);
---

<section id="toolbag" class="relative bg-fairway py-16 text-cream sm:py-20">
  <!-- Subtle grain on dark fairway felt -->
  <div
    class="pointer-events-none absolute inset-0 bg-fairway-grain bg-grain opacity-40"
    aria-hidden="true"
  ></div>

  <div class="container-club relative">
    <header class="max-w-2xl">
      <div class="flex items-center gap-3">
        <span class="h-px w-12 bg-gold"></span>
        <span class="font-mono text-[11px] uppercase tracking-widest2 text-gold">
          In the Bag · Equipment
        </span>
      </div>
      <h2 class="mt-4 font-display text-4xl leading-[1.05] text-cream sm:text-5xl">
        {toolbag.title}
      </h2>
      <p class="mt-4 max-w-xl text-balance text-base text-cream/70">
        {toolbag.caption}
      </p>
    </header>

    <div class="mt-14 space-y-12">
      {orderedCategories.map((category) => (
        <div>
          <div class="mb-5 flex items-center justify-between">
            <span class="font-mono text-[11px] uppercase tracking-widest2 text-gold">
              {category}
            </span>
            <span class="hidden h-px flex-1 bg-cream/10 sm:ml-6 sm:block"></span>
          </div>

          <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
            {grouped[category]!.map((tool) => (
              <li>
                <div
                  class="group flex items-center justify-between rounded-xl border border-cream/15 bg-fairway-light/40 px-4 py-3 transition-all duration-300 hover:border-gold hover:bg-fairway-light"
                >
                  <span class="text-sm font-medium text-cream">{tool.name}</span>
                  <!-- Club tag dot -->
                  <span
                    class="h-2 w-2 rounded-full bg-gold/50 transition-colors duration-300 group-hover:bg-gold"
                    aria-hidden="true"
                  ></span>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
