---
import { trophyCase } from '../data/content';
import SectionHeader from './SectionHeader.astro';
---

<section id="trophy-case" class="relative bg-cream-deep py-24 sm:py-28">
  <div class="container-club">
    <SectionHeader
      eyebrow={`Hole 02 · ${trophyCase.subtitle}`}
      title={trophyCase.title}
      caption={trophyCase.caption}
    />

    <ul class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {trophyCase.wins.map((win) => (
        <li class="card group relative">
          <!-- Hairline-gold corner brackets evoke a museum case -->
          <span class="pointer-events-none absolute left-3 top-3 h-3 w-3 border-l border-t border-gold/60"></span>
          <span class="pointer-events-none absolute right-3 top-3 h-3 w-3 border-r border-t border-gold/60"></span>
          <span class="pointer-events-none absolute bottom-3 left-3 h-3 w-3 border-b border-l border-gold/60"></span>
          <span class="pointer-events-none absolute bottom-3 right-3 h-3 w-3 border-b border-r border-gold/60"></span>

          <div class="flex items-center justify-between">
            <span class="label-tag">
              <span class="h-1 w-1 rounded-full bg-gold"></span>
              {win.marker}
            </span>
            <!-- Trophy chalice -->
            <svg
              class="text-gold/80 transition-transform duration-500 group-hover:scale-110"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M5 3H15V7C15 9.76142 12.7614 12 10 12C7.23858 12 5 9.76142 5 7V3Z"
                stroke="currentColor"
                stroke-width="1"
              />
              <path d="M3 4H5M15 4H17M8 16H12M10 12V16" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
            </svg>
          </div>

          <h3 class="mt-5 font-display text-2xl leading-snug text-fairway">
            {win.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-charcoal-muted">
            {win.body}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
